# Mealie - Environment Variables
#
# SECRETS - Add these to Infisical at /services/mealie/
# ─────────────────────────────────────────────────────────
OPENAI_API_KEY=                  # Required: OpenAI API key for recipe features

# Optional OpenAI overrides
# OPENAI_BASE_URL=              # Custom OpenAI-compatible endpoint (e.g. http://ollama:11434/v1)
# OPENAI_MODEL=gpt-4o           # Model to use (default: gpt-4o)

# CONFIGURATION - Set in Komodo stack settings
# ─────────────────────────────────────────────
ENV=dev                          # dev or prod
BASE_DOMAIN=thebozic.com         # Base domain for Traefik routing
TZ=America/Toronto               # Timezone
