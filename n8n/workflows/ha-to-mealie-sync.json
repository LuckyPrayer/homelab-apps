      "id": "c1d2e3f4-0020-4000-a000-000000000005",
      "name": "Get Mealie Lists",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1140, 180]
    },
    {
      "parameters": {
        "jsCode": "// Get the first shopping list ID from Mealie\nconst response = $input.first().json;\nconst lists = response.items ?? response.data ?? response;\n\nlet listId = '';\nif (Array.isArray(lists) && lists.length > 0) {\n  listId = lists[0].id;\n} else if (response.id) {\n  listId = response.id;\n}\n\n// Carry forward the item name from the HA webhook\nconst prevData = $('Parse HA Payload').first().json;\n\nreturn [{ json: { listId, itemName: prevData.itemName } }];"
      },
      "id": "c1d2e3f4-0020-4000-a000-000000000006",
