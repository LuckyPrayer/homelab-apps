    {
      "parameters": {
        "jsCode": "// Extract and normalize the HA event payload\nconst body = $input.first().json.body ?? $input.first().json;\n\nconst action = (body.action ?? '').toLowerCase();\nconst itemName = (body.item_name ?? '').trim();\nconst itemComplete = body.item_complete === true || body.item_complete === 'true' || body.item_complete === 'True';\n\nreturn [{ json: { action, itemName, itemComplete } }];"
      },
