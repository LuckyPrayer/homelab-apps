      "id": "c1d2e3f4-0020-4000-a000-000000000008",
      "name": "Fetch All Mealie Items - Update",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1140, 340]
    },
    {
      "parameters": {
        "jsCode": "// Find the Mealie item matching the HA item name\nconst response = $input.first().json;\nconst items = response.items ?? response.data ?? response;\nconst prevData = $('Parse HA Payload').first().json;\nconst targetName = prevData.itemName.toLowerCase().trim();\nconst isComplete = prevData.itemComplete;\n\nlet matchedItem = null;\n\nif (Array.isArray(items)) {\n  matchedItem = items.find(item => {\n    const note = (item.note ?? '').toLowerCase().trim();\n    const foodName = (item.food?.name ?? '').toLowerCase().trim();\n    const display = (item.display ?? '').toLowerCase().trim();\n    return note === targetName || foodName === targetName || display === targetName;\n  });\n}\n\nif (matchedItem) {\n  return [{ json: {\n    itemId: matchedItem.id,\n    shoppingListId: matchedItem.shoppingListId,\n    note: matchedItem.note ?? '',\n    quantity: matchedItem.quantity ?? 0,\n    foodId: matchedItem.foodId ?? null,\n    unitId: matchedItem.unitId ?? null,\n    labelId: matchedItem.labelId ?? null,\n    checked: isComplete,\n    found: true\n  } }];\n} else {\n  return [{ json: { found: false, itemName: prevData.itemName } }];\n}"
      },
