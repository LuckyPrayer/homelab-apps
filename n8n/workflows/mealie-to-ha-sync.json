        "jsCode": "const input = $input.first().json;\nconst itemId = input.shoppingListItemId;\nconst staticData = $getWorkflowStaticData(\"global\");\nconst cache = staticData.itemNameCache ?? {};\nconst itemName = cache[itemId];\nif (!itemName) { return []; }\ndelete cache[itemId];\nstaticData.itemNameCache = cache;\nreturn [{ json: { itemName } }];"
