    {
      "parameters": {
        "jsCode": "// Parse the Apprise JSON notification from Mealie\n// Webhook v2 wraps payload under 'body'; handle both cases\nconst raw = $input.first().json;\nconst input = raw.body ?? raw;\n\n// The document_data may arrive as JSON string or pre-parsed object.\n// Mealie/Apprise embeds Flatted-style '+' prefixes on values, e.g.\n//   {\"key\":+\"value\",+\"key2\":+\"value2\"}\n// which is NOT valid JSON, so we strip them before parsing.\nlet docData;\ntry {\n  let dd = input.document_data;\n  if (dd && typeof dd === 'object' && dd !== null) {\n    docData = dd;\n  } else if (typeof dd === 'string') {\n    // Strip Flatted-style '+' prefixes: :+\"val\" → :\"val\" and ,+\"key\" → ,\"key\"\n    const cleaned = dd.replace(/([,:\\[])\\+/g, '$1');\n    docData = JSON.parse(cleaned);\n  } else {\n    docData = {};\n  }\n} catch (e) {\n  docData = {};\n}\n\n// Support both camelCase (Mealie native) and snake_case field names\nconst eventType = input.event_type ?? '';\nconst operation = docData.operation ?? 'unknown';\nconst documentType = docData.documentType ?? docData.document_type ?? 'unknown';\nconst shoppingListId = docData.shoppingListId ?? docData.shopping_list_id ?? null;\n\nconst shoppingListItemId = docData.shoppingListItemId ?? docData.shopping_list_item_id ?? null;\nconst shoppingListItemIds = docData.shoppingListItemIds ?? docData.shopping_list_item_ids ?? [];\n\nconst itemIds = shoppingListItemId\n  ? [shoppingListItemId]\n  : (Array.isArray(shoppingListItemIds) ? shoppingListItemIds : []);\n\nif (itemIds.length === 0) {\n  return [];  // No items to sync\n}\n\nreturn itemIds.map(id => ({\n  json: {\n    eventType,\n    operation,\n    documentType,\n    shoppingListId,\n    shoppingListItemId: id,\n    integrationId: input.integration_id ?? ''\n  }\n}));"
      },
