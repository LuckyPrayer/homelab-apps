    {
      "parameters": {
        "jsCode": "// Extract item details from Mealie webhook payload\nconst body = $input.first().json.body ?? $input.first().json;\n\n// Mealie shopping list item fields\nconst note = body.note ?? body.item?.note ?? body.display ?? body.item?.display ?? '';\nconst foodName = body.food?.name ?? body.item?.food?.name ?? '';\nconst quantity = body.quantity ?? body.item?.quantity ?? '';\nconst unit = body.unit?.name ?? body.item?.unit?.name ?? '';\n\n// Build a readable item name\nlet itemName = '';\nif (foodName) {\n  itemName = foodName;\n  if (quantity) {\n    const unitStr = unit ? ` ${unit}` : '';\n    itemName = `${quantity}${unitStr} ${foodName}`;\n  }\n} else if (note) {\n  itemName = note;\n} else {\n  itemName = 'Unknown item';\n}\n\nreturn [{ json: { itemName: itemName.trim() } }];"
      },
      "id": "b1c2d3e4-0010-4000-a000-000000000004",
      "name": "Extract Item - Add",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [960, 180]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.HA_URL }}/api/services/shopping_list/add_item",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer {{ $env.HOMEASSISTANT_API_TOKEN }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
