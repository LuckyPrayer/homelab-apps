    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\nconst extras = item.extras ?? {};\nif (extras.synced_from === \"n8n\") { return []; }\nconst note = item.note ?? \"\";\nconst foodName = item.food?.name ?? \"\";\nconst quantity = item.quantity ?? \"\";\nconst unit = item.unit?.name ?? \"\";\nlet itemName = \"\";\nif (foodName) {\n  itemName = foodName;\n  if (quantity) {\n    const unitStr = unit ? \" \" + unit : \"\";\n    itemName = quantity + unitStr + \" \" + foodName;\n  }\n} else if (note) {\n  itemName = note;\n} else {\n  itemName = \"Unknown item\";\n}\nreturn [{ json: { itemName: itemName.trim() } }];"
      },
