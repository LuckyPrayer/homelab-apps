    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\nconst itemId = item.id;\nconst note = item.note ?? \"\";\nconst foodName = item.food?.name ?? \"\";\nconst quantity = item.quantity ?? \"\";\nconst unit = item.unit?.name ?? \"\";\nlet itemName = \"\";\nif (foodName) {\n  itemName = foodName;\n  if (quantity) {\n    const unitStr = unit ? \" \" + unit : \"\";\n    itemName = quantity + unitStr + \" \" + foodName;\n  }\n} else if (note) { itemName = note; }\nif (itemId && itemName) {\n  const staticData = $getWorkflowStaticData(\"global\");\n  const cache = staticData.itemNameCache ?? {};\n  cache[itemId] = itemName.trim();\n  const keys = Object.keys(cache);\n  if (keys.length > 500) { delete cache[keys[0]]; }\n  staticData.itemNameCache = cache;\n}\nreturn $input.all();"
      },
