    {
      "parameters": {
        "jsCode": "// Extract item name from Mealie delete event\nconst body = $input.first().json.body ?? $input.first().json;\n\nconst note = body.note ?? body.item?.note ?? body.display ?? body.item?.display ?? '';\nconst foodName = body.food?.name ?? body.item?.food?.name ?? '';\nconst quantity = body.quantity ?? body.item?.quantity ?? '';\nconst unit = body.unit?.name ?? body.item?.unit?.name ?? '';\n\nlet itemName = '';\nif (foodName) {\n  itemName = foodName;\n  if (quantity) {\n    const unitStr = unit ? ` ${unit}` : '';\n    itemName = `${quantity}${unitStr} ${foodName}`;\n  }\n} else if (note) {\n  itemName = note;\n} else {\n  itemName = 'Unknown item';\n}\n\nreturn [{ json: { itemName: itemName.trim() } }];"
