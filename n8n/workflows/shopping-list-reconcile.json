        "jsCode": "// Get list ID and carry forward the item to create\nconst response = $input.first().json;\nconst lists = response.items ?? response.data ?? response;\nlet listId = '';\nif (Array.isArray(lists) && lists.length > 0) {\n  listId = lists[0].id;\n}\n\n// Get the pending operation from the previous switch node output\nconst prevItem = $('Route Operations').first().json;\n\nreturn [{ json: { listId, name: prevItem.name, completed: prevItem.completed ?? false } }];"
