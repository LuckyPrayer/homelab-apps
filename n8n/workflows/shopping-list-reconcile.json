          "conditions": [
            {
              "id": "has-changes",
              "leftValue": "={{ $json.stats.toAddToHA + $json.stats.toAddToMealie + $json.stats.mismatches }}",
              "rightValue": 0,
              "operator": {
                "type": "number",
                "operation": "gt"
