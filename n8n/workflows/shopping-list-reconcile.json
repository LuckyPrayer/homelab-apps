      "id": "d1e2f3a4-0030-4000-a000-000000000003",
      "name": "Fetch HA Shopping List",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [480, 440],
      "retryOnFail": true,
      "maxTries": 2,
      "waitBetweenTries": 5000
