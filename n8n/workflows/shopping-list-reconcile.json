      "id": "d1e2f3a4-0030-4000-a000-000000000005",
      "name": "Has Changes?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [980, 340]
    },
    {
      "parameters": {
        "jsCode": "// Split into individual operations for batch processing\nconst data = $input.first().json;\nconst operations = [];\n\n// Items to add to HA\nfor (const item of data.addToHA) {\n  operations.push({\n    target: 'ha',\n    action: 'add',\n    name: item.name,\n    checked: item.checked\n  });\n}\n\n// Items to add to Mealie\nfor (const item of data.addToMealie) {\n  operations.push({\n    target: 'mealie',\n    action: 'add',\n    name: item.name,\n    completed: item.completed\n  });\n}\n\n// Status mismatches — update HA to match Mealie (source of truth)\nfor (const item of data.statusMismatches) {\n  operations.push({\n    target: 'ha',\n    action: item.mealieChecked ? 'complete' : 'incomplete',\n    name: item.name\n  });\n}\n\nif (operations.length === 0) {\n  return [{ json: { message: 'No operations needed' } }];\n}\n\nreturn operations.map(op => ({ json: op }));"
      },
