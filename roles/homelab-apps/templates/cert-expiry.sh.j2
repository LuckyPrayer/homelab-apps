#!/bin/bash
# TLS Certificate Expiry Report
# Auto-generated by Ansible homelab-apps role
#
# Checks:
#   1. Finds acme.json files (Traefik ACME storage)
#   2. Decodes certificates and checks expiry dates
#   3. Validates acme.json file permissions (must be 600)
#   4. Reports domain, issuer, expiry date, and days remaining
#
# Usage:
#   cert-expiry.sh              # Human-readable output
#   cert-expiry.sh --json       # JSON output (for Discord / monitoring)
#   cert-expiry.sh --warn N     # Warning threshold in days (default: 14)
#   cert-expiry.sh --crit N     # Critical threshold in days (default: 7)

set -euo pipefail

# =============================================================================
# Configuration (baked at deploy time by Ansible)
# =============================================================================
HOST="{{ inventory_hostname }}"
ENV="{{ env | default('dev') }}"

{% raw %}
# =============================================================================
# Argument parsing
# =============================================================================
OUTPUT_JSON=false
WARN_DAYS=14
CRIT_DAYS=7

while [[ $# -gt 0 ]]; do
    case "$1" in
        --json|-j)     OUTPUT_JSON=true; shift ;;
        --warn|-w)     WARN_DAYS="$2"; shift 2 ;;
        --crit|-c)     CRIT_DAYS="$2"; shift 2 ;;
        *)             echo "Unknown option: $1"; exit 1 ;;
    esac
done

NOW_EPOCH=$(date +%s)

# =============================================================================
# Find acme.json files
# =============================================================================

ACME_PATHS=()
SEARCH_DIRS=(
    "/opt/stacks/traefik/config"
    "/opt/homelab/traefik"
    "/opt/infrastructure/traefik-proxy"
    "/opt/infrastructure/traefik"
    "/opt/traefik"
)

for dir in "${SEARCH_DIRS[@]}"; do
    if [[ -f "$dir/acme.json" ]]; then
        ACME_PATHS+=("$dir/acme.json")
    fi
done

# Fallback: search /opt for any acme.json
if [[ ${#ACME_PATHS[@]} -eq 0 ]]; then
    while IFS= read -r p; do
        ACME_PATHS+=("$p")
    done < <(find /opt -name "acme.json" -type f 2>/dev/null || true)
fi

# =============================================================================
# Parse certificates
# =============================================================================

TOTAL_CERTS=0
VALID_CERTS=0
EXPIRING_CERTS=0
EXPIRED_CERTS=0
ISSUES=0
WARNINGS=0

# Certificate details arrays
CERT_DOMAINS=()
CERT_SANS=()
CERT_EXPIRY_DATES=()
CERT_DAYS_LEFT=()
CERT_ISSUERS=()
CERT_RESOLVERS=()
CERT_STATUSES=()

# File permission issues
PERM_ISSUES=()

# acme.json file details
ACME_FILE_COUNT=${#ACME_PATHS[@]}

for acme_file in "${ACME_PATHS[@]}"; do
    # --- Check file permissions ---
    file_perms=$(stat -c '%a' "$acme_file" 2>/dev/null || echo "000")
    file_owner=$(stat -c '%U:%G' "$acme_file" 2>/dev/null || echo "unknown")
    if [[ "$file_perms" != "600" ]]; then
        PERM_ISSUES+=("${acme_file}|${file_perms}|${file_owner}")
        WARNINGS=$((WARNINGS + 1))
    fi

    # --- Parse certificates from acme.json ---
    if ! command -v python3 &>/dev/null; then
        continue
    fi

    # Use python3 to extract cert data from acme.json
    cert_data=$(python3 -c "
import json, base64, sys
try:
    with open('$acme_file') as f:
        data = json.load(f)
except Exception as e:
    sys.exit(0)
for resolver_name, resolver_data in data.items():
    certs = resolver_data.get('Certificates', resolver_data.get('certificates', []))
    if not certs:
        continue
    for cert_entry in certs:
        domain_info = cert_entry.get('domain', cert_entry.get('Domain', {}))
        main_domain = domain_info.get('main', 'unknown')
        sans = domain_info.get('sans', []) or []
        cert_pem_b64 = cert_entry.get('certificate', cert_entry.get('Certificate', ''))
        if cert_pem_b64:
            try:
                cert_pem = base64.b64decode(cert_pem_b64).decode('utf-8', errors='replace')
                sans_str = ','.join(sans) if sans else ''
                pem_oneline = cert_pem.replace(chr(10), '%%NL%%')
                print(f'{resolver_name}|{main_domain}|{sans_str}|{pem_oneline}')
            except Exception:
                print(f'{resolver_name}|{main_domain}|ERROR')
" 2>/dev/null || true)

    while IFS='|' read -r resolver domain sans pem_data; do
        [[ -z "$resolver" ]] && continue
        [[ "$pem_data" == "ERROR" ]] && continue

        TOTAL_CERTS=$((TOTAL_CERTS + 1))

        # Restore newlines and extract first certificate from chain
        cert_pem=$(echo "$pem_data" | sed 's/%%NL%%/\n/g')

        # Parse expiry with openssl
        expiry_str=$(echo "$cert_pem" | openssl x509 -noout -enddate 2>/dev/null | sed 's/notAfter=//' || echo "")
        issuer_str=$(echo "$cert_pem" | openssl x509 -noout -issuer 2>/dev/null | sed 's/issuer=//' | sed 's/.*CN *= *//' | sed 's/,.*//' || echo "unknown")

        if [[ -z "$expiry_str" ]]; then
            CERT_STATUSES+=("error")
            CERT_DOMAINS+=("$domain")
            CERT_SANS+=("$sans")
            CERT_EXPIRY_DATES+=("unknown")
            CERT_DAYS_LEFT+=("-1")
            CERT_ISSUERS+=("unknown")
            CERT_RESOLVERS+=("$resolver")
            ISSUES=$((ISSUES + 1))
            continue
        fi

        expiry_epoch=$(date -d "$expiry_str" +%s 2>/dev/null || echo "0")
        days_left=$(( (expiry_epoch - NOW_EPOCH) / 86400 ))

        CERT_DOMAINS+=("$domain")
        CERT_SANS+=("$sans")
        CERT_EXPIRY_DATES+=("$(date -d "$expiry_str" '+%Y-%m-%d %H:%M UTC' 2>/dev/null || echo "$expiry_str")")
        CERT_DAYS_LEFT+=("$days_left")
        CERT_ISSUERS+=("$issuer_str")
        CERT_RESOLVERS+=("$resolver")

        if [[ $days_left -lt 0 ]]; then
            CERT_STATUSES+=("expired")
            EXPIRED_CERTS=$((EXPIRED_CERTS + 1))
            ISSUES=$((ISSUES + 1))
        elif [[ $days_left -lt $CRIT_DAYS ]]; then
            CERT_STATUSES+=("critical")
            EXPIRING_CERTS=$((EXPIRING_CERTS + 1))
            ISSUES=$((ISSUES + 1))
        elif [[ $days_left -lt $WARN_DAYS ]]; then
            CERT_STATUSES+=("warning")
            EXPIRING_CERTS=$((EXPIRING_CERTS + 1))
            WARNINGS=$((WARNINGS + 1))
        else
            CERT_STATUSES+=("ok")
            VALID_CERTS=$((VALID_CERTS + 1))
        fi
    done <<< "$cert_data"
done

# =============================================================================
# No Traefik — still valid result
# =============================================================================
HAS_TRAEFIK=true
if [[ ${#ACME_PATHS[@]} -eq 0 ]]; then
    HAS_TRAEFIK=false
fi

# =============================================================================
# Output
# =============================================================================

if $OUTPUT_JSON; then
    # Build certificates JSON array
    CERTS_JSON="["
    for i in $(seq 0 $((TOTAL_CERTS - 1))); do
        [[ $i -gt 0 ]] && CERTS_JSON+=","
        sans_json="[]"
        if [[ -n "${CERT_SANS[$i]}" ]]; then
            sans_json="[$(echo "${CERT_SANS[$i]}" | tr ',' '\n' | sed 's/.*/"&"/' | tr '\n' ',' | sed 's/,$//')]"
        fi
        CERTS_JSON+="{\"domain\":\"${CERT_DOMAINS[$i]}\",\"sans\":${sans_json},\"resolver\":\"${CERT_RESOLVERS[$i]}\",\"issuer\":\"${CERT_ISSUERS[$i]}\",\"expiry\":\"${CERT_EXPIRY_DATES[$i]}\",\"days_left\":${CERT_DAYS_LEFT[$i]},\"status\":\"${CERT_STATUSES[$i]}\"}"
    done
    CERTS_JSON+="]"

    # Build permission issues JSON
    PERM_JSON="["
    for i in $(seq 0 $((${#PERM_ISSUES[@]} - 1))); do
        [[ $i -gt 0 ]] && PERM_JSON+=","
        IFS='|' read -r pfile pperms powner <<< "${PERM_ISSUES[$i]}"
        PERM_JSON+="{\"file\":\"$pfile\",\"permissions\":\"$pperms\",\"owner\":\"$powner\"}"
    done
    PERM_JSON+="]"

    cat <<JSONEOF
{
  "host": "$HOST",
  "env": "$ENV",
  "timestamp": "$(date -u +%Y-%m-%dT%H:%M:%SZ)",
  "has_traefik": $HAS_TRAEFIK,
  "acme_files": $ACME_FILE_COUNT,
  "warn_days": $WARN_DAYS,
  "crit_days": $CRIT_DAYS,
  "issues": $ISSUES,
  "warnings": $WARNINGS,
  "summary": {
    "total": $TOTAL_CERTS,
    "valid": $VALID_CERTS,
    "expiring": $EXPIRING_CERTS,
    "expired": $EXPIRED_CERTS
  },
  "certificates": $CERTS_JSON,
  "permission_issues": $PERM_JSON
}
JSONEOF
    exit 0
fi

# --- Human-readable output ---
echo ""
echo "════════════════════════════════════════════════════════════════"
echo "  TLS Certificate Expiry - $HOST ($ENV)"
echo "  $(date -u +%Y-%m-%dT%H:%M:%SZ)  ·  Warn: ${WARN_DAYS}d  Crit: ${CRIT_DAYS}d"
echo "════════════════════════════════════════════════════════════════"

if [[ "$HAS_TRAEFIK" == "false" ]]; then
    echo ""
    echo "┌─ Traefik ──────────────────────────────────────────────────"
    echo "│  ℹ No acme.json found — Traefik may not be running on this host"
    echo "└────────────────────────────────────────────────────────────"
    echo ""
    echo "────────────────────────────────────────────────────────────────"
    echo "  ℹ No certificates to check"
    echo "────────────────────────────────────────────────────────────────"
    exit 0
fi

# --- ACME Files ---
echo ""
echo "┌─ ACME Storage ────────────────────────────────────────────"
for acme_file in "${ACME_PATHS[@]}"; do
    file_perms=$(stat -c '%a' "$acme_file" 2>/dev/null || echo "???")
    file_owner=$(stat -c '%U:%G' "$acme_file" 2>/dev/null || echo "???")
    file_size=$(stat -c '%s' "$acme_file" 2>/dev/null || echo "0")
    file_size_kb=$(( file_size / 1024 ))
    if [[ "$file_perms" == "600" ]]; then
        echo "│  ✓ $acme_file  (${file_perms}, ${file_owner}, ${file_size_kb}KB)"
    else
        echo "│  ⚠ $acme_file  (${file_perms} ← should be 600, ${file_owner}, ${file_size_kb}KB)"
    fi
done
echo "└────────────────────────────────────────────────────────────"

# --- Certificates ---
echo ""
echo "┌─ Certificates ($TOTAL_CERTS) ─────────────────────────────"

if [[ $TOTAL_CERTS -eq 0 ]]; then
    echo "│  ⚠ No certificates found in acme.json"
else
    # Sort by days_left (most urgent first) — use indices
    sorted_indices=$(for i in $(seq 0 $((TOTAL_CERTS - 1))); do echo "${CERT_DAYS_LEFT[$i]} $i"; done | sort -n | awk '{print $2}')

    for idx in $sorted_indices; do
        domain="${CERT_DOMAINS[$idx]}"
        days="${CERT_DAYS_LEFT[$idx]}"
        expiry="${CERT_EXPIRY_DATES[$idx]}"
        status="${CERT_STATUSES[$idx]}"
        issuer="${CERT_ISSUERS[$idx]}"

        case "$status" in
            expired)   icon="✗"; label="EXPIRED" ;;
            critical)  icon="✗"; label="${days}d left" ;;
            warning)   icon="⚠"; label="${days}d left" ;;
            ok)        icon="✓"; label="${days}d left" ;;
            *)         icon="?"; label="unknown" ;;
        esac

        printf "│  %s %-40s  %s  (%s)\n" "$icon" "$domain" "$label" "$expiry"
    done
fi
echo "└────────────────────────────────────────────────────────────"

# --- Summary ---
echo ""
if [[ $ISSUES -gt 0 ]]; then
    echo "────────────────────────────────────────────────────────────────"
    echo "  ✗ $EXPIRED_CERTS expired · $EXPIRING_CERTS expiring soon · $VALID_CERTS valid"
    echo "────────────────────────────────────────────────────────────────"
    exit 2
elif [[ $WARNINGS -gt 0 ]]; then
    echo "────────────────────────────────────────────────────────────────"
    echo "  ⚠ $WARNINGS warning(s) — $EXPIRING_CERTS expiring soon · $VALID_CERTS valid"
    echo "────────────────────────────────────────────────────────────────"
    exit 1
else
    echo "────────────────────────────────────────────────────────────────"
    echo "  ✓ All $VALID_CERTS certificate(s) valid"
    echo "────────────────────────────────────────────────────────────────"
    exit 0
fi
{% endraw %}
