#!/bin/bash
# Security Audit Report
# Auto-generated by Ansible homelab-apps role
#
# Checks:
#   1. Fail2Ban status & recent bans
#   2. SSH authentication (failed logins past 7 days)
#   3. Listening network ports
#   4. Pending security updates
#   5. Docker container security posture
#
# Usage:
#   security-audit.sh              # Human-readable output
#   security-audit.sh --json       # JSON output (for Discord / monitoring)
#   security-audit.sh --days N     # Look back N days (default: 7)

set -euo pipefail

# =============================================================================
# Configuration (baked at deploy time by Ansible)
# =============================================================================
HOST="{{ inventory_hostname }}"
ENV="{{ env | default('dev') }}"

{% raw %}
# =============================================================================
# Argument parsing
# =============================================================================
OUTPUT_JSON=false
LOOKBACK_DAYS=7

while [[ $# -gt 0 ]]; do
    case "$1" in
        --json|-j)     OUTPUT_JSON=true; shift ;;
        --days|-d)     LOOKBACK_DAYS="$2"; shift 2 ;;
        *)             echo "Unknown option: $1"; exit 1 ;;
    esac
done

SINCE_DATE=$(date -d "${LOOKBACK_DAYS} days ago" '+%Y-%m-%d')

# =============================================================================
# Collect data
# =============================================================================

# --- 1. Fail2Ban ---
F2B_RUNNING=false
F2B_JAILS=()
F2B_TOTAL_BANNED=0
F2B_CURRENT_BANNED=0
F2B_BANNED_IPS=""
F2B_JAIL_DETAILS=""

if command -v fail2ban-client &>/dev/null; then
    if fail2ban-client status &>/dev/null; then
        F2B_RUNNING=true
        # Get jail list
        mapfile -t F2B_JAILS < <(fail2ban-client status 2>/dev/null | grep "Jail list:" | sed 's/.*Jail list:\s*//' | tr ',' '\n' | sed 's/^[[:space:]]*//' | sed 's/[[:space:]]*$//')

        for jail in "${F2B_JAILS[@]}"; do
            [[ -z "$jail" ]] && continue
            jail_output=$(fail2ban-client status "$jail" 2>/dev/null || true)
            currently=$(echo "$jail_output" | grep "Currently banned:" | awk '{print $NF}')
            total=$(echo "$jail_output" | grep "Total banned:" | awk '{print $NF}')
            banned_list=$(echo "$jail_output" | grep "Banned IP list:" | sed 's/.*Banned IP list:\s*//')
            currently=${currently:-0}
            total=${total:-0}
            F2B_TOTAL_BANNED=$((F2B_TOTAL_BANNED + total))
            F2B_CURRENT_BANNED=$((F2B_CURRENT_BANNED + currently))
            if [[ -n "$banned_list" && "$banned_list" != " " ]]; then
                F2B_BANNED_IPS="${F2B_BANNED_IPS}${jail}: ${banned_list}\n"
            fi
            F2B_JAIL_DETAILS="${F2B_JAIL_DETAILS}${jail}|${currently}|${total}\n"
        done
    fi
fi

# --- 2. SSH Authentication ---
SSH_FAILED_LOGINS=0
SSH_FAILED_IPS=""
SSH_ACCEPTED_LOGINS=0

# Try journalctl for SSH logs (systemd-based systems)
if command -v journalctl &>/dev/null; then
    # Count failed SSH attempts
    SSH_FAILED_LOGINS=$(journalctl -u ssh -u sshd --since "$SINCE_DATE" --no-pager 2>/dev/null \
        | grep -c -E "Failed password|authentication failure|Invalid user|Connection closed by.*preauth" || true)
    SSH_FAILED_LOGINS=${SSH_FAILED_LOGINS:-0}

    # Get top offending IPs for failed logins
    SSH_FAILED_IPS=$(journalctl -u ssh -u sshd --since "$SINCE_DATE" --no-pager 2>/dev/null \
        | grep -E "Failed password|Invalid user" \
        | grep -oP 'from \K[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+' \
        | sort | uniq -c | sort -rn | head -10 2>/dev/null || true)

    # Count accepted logins
    SSH_ACCEPTED_LOGINS=$(journalctl -u ssh -u sshd --since "$SINCE_DATE" --no-pager 2>/dev/null \
        | grep -c "Accepted" || true)
    SSH_ACCEPTED_LOGINS=${SSH_ACCEPTED_LOGINS:-0}
fi

# --- 3. Listening Ports ---
LISTENING_PORTS=""
if command -v ss &>/dev/null; then
    LISTENING_PORTS=$(ss -tlnp 2>/dev/null | tail -n +2 | awk '{print $4, $6}' | sed 's/users:(("//' | sed 's/".*//') || true
fi
LISTEN_COUNT=0
if [[ -n "$LISTENING_PORTS" ]]; then
    LISTEN_COUNT=$(echo "$LISTENING_PORTS" | wc -l)
fi

# --- 4. Pending Security Updates ---
PENDING_UPDATES=0
PENDING_LIST=""
UPDATES_AVAILABLE=false

if command -v apt-get &>/dev/null; then
    # Check for security updates
    PENDING_LIST=$(apt-get -s upgrade 2>/dev/null | grep "^Inst" | grep -i "securi" || true)
    if [[ -n "$PENDING_LIST" ]]; then
        PENDING_UPDATES=$(echo "$PENDING_LIST" | wc -l)
    fi
    if [[ $PENDING_UPDATES -gt 0 ]]; then
        UPDATES_AVAILABLE=true
    fi
fi

# Auto-upgrade status
AUTOUPGRADE_ENABLED=false
if systemctl is-active --quiet unattended-upgrades 2>/dev/null; then
    AUTOUPGRADE_ENABLED=true
fi

# Last unattended-upgrade run
LAST_UPGRADE_TIME=""
if [[ -f /var/log/unattended-upgrades/unattended-upgrades.log ]]; then
    LAST_UPGRADE_TIME=$(stat -c '%Y' /var/log/unattended-upgrades/unattended-upgrades.log 2>/dev/null || echo "")
    if [[ -n "$LAST_UPGRADE_TIME" ]]; then
        LAST_UPGRADE_TIME=$(date -d "@$LAST_UPGRADE_TIME" '+%Y-%m-%d %H:%M' 2>/dev/null || echo "unknown")
    fi
fi

# Needs restart?
NEEDS_RESTART=false
if [[ -f /var/run/reboot-required ]]; then
    NEEDS_RESTART=true
fi

# --- 5. Docker Security ---
DOCKER_PRIVILEGED=()
DOCKER_HOST_NET=()
DOCKER_ROOT_USERS=()
DOCKER_ISSUES=0

if command -v docker &>/dev/null; then
    # Get all running container names
    mapfile -t CONTAINERS < <(docker ps --format '{{.Names}}' 2>/dev/null)

    for cname in "${CONTAINERS[@]}"; do
        [[ -z "$cname" ]] && continue

        # Check privileged mode
        is_privileged=$(docker inspect --format '{{.HostConfig.Privileged}}' "$cname" 2>/dev/null || echo "false")
        if [[ "$is_privileged" == "true" ]]; then
            DOCKER_PRIVILEGED+=("$cname")
            DOCKER_ISSUES=$((DOCKER_ISSUES + 1))
        fi

        # Check host network mode
        net_mode=$(docker inspect --format '{{.HostConfig.NetworkMode}}' "$cname" 2>/dev/null || echo "")
        if [[ "$net_mode" == "host" ]]; then
            DOCKER_HOST_NET+=("$cname")
            # Host networking is informational, not necessarily an issue
        fi
    done
fi

CONTAINER_COUNT=${#CONTAINERS[@]}

# =============================================================================
# Output
# =============================================================================

# Determine overall status
ISSUES=0
WARNINGS=0

[[ "$F2B_RUNNING" == "false" ]] && command -v fail2ban-client &>/dev/null && WARNINGS=$((WARNINGS + 1))
[[ $F2B_CURRENT_BANNED -gt 0 ]] && WARNINGS=$((WARNINGS + 1))
[[ $SSH_FAILED_LOGINS -gt 50 ]] && WARNINGS=$((WARNINGS + 1))
[[ $SSH_FAILED_LOGINS -gt 200 ]] && ISSUES=$((ISSUES + 1))
[[ $PENDING_UPDATES -gt 0 ]] && WARNINGS=$((WARNINGS + 1))
[[ "$NEEDS_RESTART" == "true" ]] && WARNINGS=$((WARNINGS + 1))
[[ $DOCKER_ISSUES -gt 0 ]] && WARNINGS=$((WARNINGS + 1))

if $OUTPUT_JSON; then
    cat <<JSONEOF
{
  "host": "$HOST",
  "env": "$ENV",
  "timestamp": "$(date -u +%Y-%m-%dT%H:%M:%SZ)",
  "lookback_days": $LOOKBACK_DAYS,
  "issues": $ISSUES,
  "warnings": $WARNINGS,
  "fail2ban": {
    "installed": $(command -v fail2ban-client &>/dev/null && echo true || echo false),
    "running": $F2B_RUNNING,
    "jails": ${#F2B_JAILS[@]},
    "jail_names": [$(printf '"%s",' "${F2B_JAILS[@]}" 2>/dev/null | sed 's/,$//')],
    "currently_banned": $F2B_CURRENT_BANNED,
    "total_banned": $F2B_TOTAL_BANNED
  },
  "ssh": {
    "failed_logins": $SSH_FAILED_LOGINS,
    "accepted_logins": $SSH_ACCEPTED_LOGINS,
    "top_offenders": [$(echo "$SSH_FAILED_IPS" | awk 'NF{printf "{\"count\":%s,\"ip\":\"%s\"},", $1, $2}' | sed 's/,$//')]
  },
  "network": {
    "listening_ports": $LISTEN_COUNT
  },
  "updates": {
    "pending_security": $PENDING_UPDATES,
    "auto_upgrade_enabled": $AUTOUPGRADE_ENABLED,
    "needs_restart": $NEEDS_RESTART,
    "last_upgrade": "$(echo "$LAST_UPGRADE_TIME")"
  },
  "docker": {
    "total_containers": $CONTAINER_COUNT,
    "privileged_containers": [$(printf '"%s",' "${DOCKER_PRIVILEGED[@]}" 2>/dev/null | sed 's/,$//')],
    "host_network_containers": [$(printf '"%s",' "${DOCKER_HOST_NET[@]}" 2>/dev/null | sed 's/,$//')],
    "security_issues": $DOCKER_ISSUES
  }
}
JSONEOF
    exit 0
fi

# --- Human-readable output ---
echo ""
echo "════════════════════════════════════════════════════════════════"
echo "  Security Audit - $HOST ($ENV)"
echo "  $(date -u +%Y-%m-%dT%H:%M:%SZ)  ·  Past ${LOOKBACK_DAYS} days"
echo "════════════════════════════════════════════════════════════════"

# --- Fail2Ban Section ---
echo ""
echo "┌─ Fail2Ban ─────────────────────────────────────────────────"
if ! command -v fail2ban-client &>/dev/null; then
    echo "│  ⚠ fail2ban not installed"
elif [[ "$F2B_RUNNING" == "false" ]]; then
    echo "│  ✗ fail2ban installed but NOT running"
else
    echo "│  ✓ fail2ban active  ·  ${#F2B_JAILS[@]} jail(s)"
    echo -e "$F2B_JAIL_DETAILS" | while IFS='|' read -r jail curr tot; do
        [[ -z "$jail" ]] && continue
        if [[ "$curr" -gt 0 ]]; then
            printf "│    ⚠ %-20s  %s currently banned  (%s total)\n" "$jail" "$curr" "$tot"
        else
            printf "│    ✓ %-20s  0 currently banned  (%s total)\n" "$jail" "$tot"
        fi
    done
    if [[ $F2B_CURRENT_BANNED -gt 0 ]]; then
        echo "│"
        echo "│  Currently banned IPs:"
        echo -e "$F2B_BANNED_IPS" | while read -r line; do
            [[ -z "$line" ]] && continue
            echo "│    $line"
        done
    fi
fi
echo "└────────────────────────────────────────────────────────────"

# --- SSH Section ---
echo ""
echo "┌─ SSH Authentication ───────────────────────────────────────"
if [[ $SSH_FAILED_LOGINS -gt 200 ]]; then
    echo "│  ✗ $SSH_FAILED_LOGINS failed login attempts (HIGH)"
elif [[ $SSH_FAILED_LOGINS -gt 50 ]]; then
    echo "│  ⚠ $SSH_FAILED_LOGINS failed login attempts (elevated)"
elif [[ $SSH_FAILED_LOGINS -gt 0 ]]; then
    echo "│  ℹ $SSH_FAILED_LOGINS failed login attempts (normal)"
else
    echo "│  ✓ No failed login attempts"
fi
echo "│  ✓ $SSH_ACCEPTED_LOGINS successful logins"

if [[ -n "$SSH_FAILED_IPS" ]]; then
    echo "│"
    echo "│  Top offending IPs:"
    echo "$SSH_FAILED_IPS" | while read -r count ip; do
        [[ -z "$count" ]] && continue
        printf "│    %6s attempts from %s\n" "$count" "$ip"
    done
fi
echo "└────────────────────────────────────────────────────────────"

# --- Updates Section ---
echo ""
echo "┌─ System Updates ───────────────────────────────────────────"
if [[ "$AUTOUPGRADE_ENABLED" == "true" ]]; then
    echo "│  ✓ Unattended upgrades enabled"
else
    echo "│  ⚠ Unattended upgrades NOT enabled"
fi
if [[ -n "$LAST_UPGRADE_TIME" ]]; then
    echo "│  ℹ Last upgrade activity: $LAST_UPGRADE_TIME"
fi
if [[ $PENDING_UPDATES -gt 0 ]]; then
    echo "│  ⚠ $PENDING_UPDATES pending security update(s)"
    echo "$PENDING_LIST" | while read -r line; do
        pkg=$(echo "$line" | awk '{print $2}')
        echo "│    • $pkg"
    done
else
    echo "│  ✓ No pending security updates"
fi
if [[ "$NEEDS_RESTART" == "true" ]]; then
    echo "│  ⚠ System reboot required"
else
    echo "│  ✓ No reboot required"
fi
echo "└────────────────────────────────────────────────────────────"

# --- Docker Section ---
echo ""
echo "┌─ Docker Security ──────────────────────────────────────────"
echo "│  ℹ $CONTAINER_COUNT running containers"
if [[ ${#DOCKER_PRIVILEGED[@]} -gt 0 ]]; then
    echo "│  ⚠ Privileged containers:"
    for c in "${DOCKER_PRIVILEGED[@]}"; do
        echo "│    • $c"
    done
else
    echo "│  ✓ No privileged containers"
fi
if [[ ${#DOCKER_HOST_NET[@]} -gt 0 ]]; then
    echo "│  ℹ Host-networked containers:"
    for c in "${DOCKER_HOST_NET[@]}"; do
        echo "│    • $c"
    done
else
    echo "│  ✓ No host-networked containers"
fi
echo "└────────────────────────────────────────────────────────────"

# --- Listening Ports ---
echo ""
echo "┌─ Listening Ports ($LISTEN_COUNT) ──────────────────────────"
echo "$LISTENING_PORTS" | while read -r addr proc; do
    [[ -z "$addr" ]] && continue
    printf "│  %-25s  %s\n" "$addr" "$proc"
done
echo "└────────────────────────────────────────────────────────────"

# --- Summary ---
echo ""
if [[ $ISSUES -gt 0 ]]; then
    echo "────────────────────────────────────────────────────────────────"
    echo "  ✗ $ISSUES issue(s) · $WARNINGS warning(s) detected"
    echo "────────────────────────────────────────────────────────────────"
    exit 2
elif [[ $WARNINGS -gt 0 ]]; then
    echo "────────────────────────────────────────────────────────────────"
    echo "  ⚠ $WARNINGS warning(s) — review recommended"
    echo "────────────────────────────────────────────────────────────────"
    exit 1
else
    echo "────────────────────────────────────────────────────────────────"
    echo "  ✓ No security issues detected"
    echo "────────────────────────────────────────────────────────────────"
    exit 0
fi
{% endraw %}