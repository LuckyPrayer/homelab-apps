#!/bin/bash
# User & Sudo Audit Report
# Auto-generated by Ansible homelab-apps role
#
# Checks:
#   1. Unexpected UIDs ≥ 1000 (accounts not in the expected list)
#   2. Sudoers scope audit (flags blanket NOPASSWD: ALL entries)
#   3. SSH authorized_keys audit (unexpected keys or key files)
#
# Usage:
#   user-audit.sh              # Human-readable output
#   user-audit.sh --json       # JSON output (for Discord / monitoring)

set -euo pipefail

# =============================================================================
# Configuration (baked at deploy time by Ansible)
# =============================================================================
HOST="{{ inventory_hostname }}"
ENV="{{ env | default('dev') }}"

{% raw %}
# =============================================================================
# Argument parsing
# =============================================================================
OUTPUT_JSON=false

while [[ $# -gt 0 ]]; do
    case "$1" in
        --json|-j)     OUTPUT_JSON=true; shift ;;
        *)             echo "Unknown option: $1"; exit 1 ;;
    esac
done

# =============================================================================
# Expected baselines
# =============================================================================

# Users expected to have UID >= 1000 on provisioned homelab hosts
# These are created by Ansible playbooks during provisioning
EXPECTED_USERS=(
    "luckyprayer"
    "ansible"
    "backup-svc"
    "docker-svc"
    "harbor-svc"
    "n8nuser"
    "semaphore-svc"
    "oracle"
    "backupuser"
)

# SSH key fingerprint comments expected in authorized_keys
# These identify known keys by their comment field
EXPECTED_KEY_COMMENTS=(
    "luckyprayer@starkiller"
    "luckyprayer@Odysseus"
    "n8nuser@homelab"
    "homelab-backup-rsync"
    "semaphore-svc"
)

# Users expected to have blanket NOPASSWD: ALL
# These are accepted but still flagged as informational
ACCEPTED_BLANKET_SUDO=(
    "root"
    "luckyprayer"
    "semaphore-svc"
)

# =============================================================================
# Counters
# =============================================================================
ISSUES=0
WARNINGS=0

# =============================================================================
# 1. UID Audit — users with UID >= 1000
# =============================================================================

declare -a USER_NAMES=()
declare -a USER_UIDS=()
declare -a USER_HOMES=()
declare -a USER_SHELLS=()
declare -a USER_STATUSES=()  # "expected" or "unexpected"

while IFS=: read -r uname _ uid _ _ home shell; do
    [[ -z "$uname" ]] && continue
    [[ "$uid" -lt 1000 ]] && continue
    [[ "$uname" == "nobody" || "$uname" == "nfsnobody" ]] && continue

    USER_NAMES+=("$uname")
    USER_UIDS+=("$uid")
    USER_HOMES+=("$home")
    USER_SHELLS+=("$shell")

    is_expected=false
    for eu in "${EXPECTED_USERS[@]}"; do
        if [[ "$uname" == "$eu" ]]; then
            is_expected=true
            break
        fi
    done

    if $is_expected; then
        USER_STATUSES+=("expected")
    else
        USER_STATUSES+=("unexpected")
        WARNINGS=$((WARNINGS + 1))
    fi
done < /etc/passwd

TOTAL_USERS=${#USER_NAMES[@]}
UNEXPECTED_USERS=0
for s in "${USER_STATUSES[@]}"; do
    [[ "$s" == "unexpected" ]] && UNEXPECTED_USERS=$((UNEXPECTED_USERS + 1))
done

# =============================================================================
# 2. Sudoers Audit — check for blanket NOPASSWD: ALL
# =============================================================================

declare -a SUDO_USERS=()
declare -a SUDO_SOURCES=()
declare -a SUDO_RULES=()
declare -a SUDO_SCOPED=()  # "blanket", "scoped", or "group"

# Parse main sudoers
while IFS= read -r line; do
    [[ -z "$line" ]] && continue
    # Skip Defaults, @include, and comments
    [[ "$line" =~ ^(Defaults|@include|#) ]] && continue

    if echo "$line" | grep -qi 'NOPASSWD.*ALL'; then
        user_field=$(echo "$line" | awk '{print $1}')
        SUDO_USERS+=("$user_field")
        SUDO_SOURCES+=("/etc/sudoers")
        SUDO_RULES+=("$line")
        if [[ "$user_field" == "%sudo" || "$user_field" == "%wheel" ]]; then
            SUDO_SCOPED+=("group")
        else
            SUDO_SCOPED+=("blanket")
        fi
    elif echo "$line" | grep -qi 'ALL=(ALL'; then
        user_field=$(echo "$line" | awk '{print $1}')
        SUDO_USERS+=("$user_field")
        SUDO_SOURCES+=("/etc/sudoers")
        SUDO_RULES+=("$line")
        if [[ "$user_field" == "%sudo" || "$user_field" == "%wheel" ]]; then
            SUDO_SCOPED+=("group")
        else
            SUDO_SCOPED+=("scoped")
        fi
    fi
done < <(grep -v '^#' /etc/sudoers 2>/dev/null | grep -v '^$' || true)

# Parse sudoers.d drop-ins
if [[ -d /etc/sudoers.d ]]; then
    for f in /etc/sudoers.d/*; do
        [[ ! -f "$f" ]] && continue
        fname=$(basename "$f")
        while IFS= read -r line; do
            [[ -z "$line" ]] && continue
            [[ "$line" =~ ^(Defaults|@include|#) ]] && continue

            user_field=$(echo "$line" | awk '{print $1}')

            if echo "$line" | grep -qi 'NOPASSWD.*ALL'; then
                # Check if it's truly blanket (ALL=(ALL) NOPASSWD: ALL)
                # vs scoped (specific commands after NOPASSWD:)
                if echo "$line" | grep -qiP 'NOPASSWD:\s*ALL\s*$'; then
                    SUDO_USERS+=("$user_field")
                    SUDO_SOURCES+=("/etc/sudoers.d/$fname")
                    SUDO_RULES+=("$line")
                    SUDO_SCOPED+=("blanket")
                else
                    SUDO_USERS+=("$user_field")
                    SUDO_SOURCES+=("/etc/sudoers.d/$fname")
                    SUDO_RULES+=("$line")
                    SUDO_SCOPED+=("scoped")
                fi
            elif echo "$line" | grep -qi 'NOPASSWD:'; then
                SUDO_USERS+=("$user_field")
                SUDO_SOURCES+=("/etc/sudoers.d/$fname")
                SUDO_RULES+=("$line")
                SUDO_SCOPED+=("scoped")
            fi
        done < <(grep -v '^#' "$f" 2>/dev/null | grep -v '^$' || true)
    done
fi

TOTAL_SUDO_ENTRIES=${#SUDO_USERS[@]}
BLANKET_SUDO=0
SCOPED_SUDO=0
for s in "${SUDO_SCOPED[@]}"; do
    [[ "$s" == "blanket" ]] && BLANKET_SUDO=$((BLANKET_SUDO + 1))
    [[ "$s" == "scoped" ]] && SCOPED_SUDO=$((SCOPED_SUDO + 1))
done

# Count blanket entries that are NOT in the accepted list
UNEXPECTED_BLANKET=0
for i in "${!SUDO_SCOPED[@]}"; do
    if [[ "${SUDO_SCOPED[$i]}" == "blanket" ]]; then
        is_accepted=false
        for au in "${ACCEPTED_BLANKET_SUDO[@]}"; do
            if [[ "${SUDO_USERS[$i]}" == "$au" ]]; then
                is_accepted=true
                break
            fi
        done
        if ! $is_accepted; then
            UNEXPECTED_BLANKET=$((UNEXPECTED_BLANKET + 1))
            ISSUES=$((ISSUES + 1))
        fi
    fi
done

# =============================================================================
# 3. SSH Authorized Keys Audit
# =============================================================================

declare -a KEY_USERS=()
declare -a KEY_TYPES=()
declare -a KEY_COMMENTS=()
declare -a KEY_STATUSES=()  # "expected", "unexpected", "duplicate"
declare -a KEY_FILES=()
declare -a KEY_OPTIONS=()   # forced-command, restrictions, etc.

check_authorized_keys() {
    local user="$1"
    local home="$2"
    local key_file="$home/.ssh/authorized_keys"

    [[ ! -f "$key_file" ]] && return 0

    local seen_keys=()
    while IFS= read -r line; do
        [[ -z "$line" ]] && continue
        [[ "$line" =~ ^# ]] && continue

        # Extract key type, key data, and comment
        local options=""
        local key_type=""
        local key_data=""
        local comment=""

        # Check if line starts with options (not a key type)
        if [[ "$line" =~ ^(ssh-rsa|ssh-ed25519|ecdsa-sha2|ssh-dss) ]]; then
            key_type=$(echo "$line" | awk '{print $1}')
            key_data=$(echo "$line" | awk '{print $2}')
            comment=$(echo "$line" | awk '{for(i=3;i<=NF;i++) printf "%s ", $i; print ""}' | sed 's/ *$//')
        else
            # Has options prefix (e.g., no-port-forwarding,command="...")
            options=$(echo "$line" | sed -E 's/(ssh-rsa|ssh-ed25519|ecdsa-sha2|ssh-dss).*//' | sed 's/ *$//')
            key_type=$(echo "$line" | grep -oP '(ssh-rsa|ssh-ed25519|ecdsa-sha2-nistp\d+|ssh-dss)' | head -1)
            key_data=$(echo "$line" | grep -oP '(ssh-rsa|ssh-ed25519|ecdsa-sha2-nistp\d+|ssh-dss)\s+\S+' | awk '{print $2}')
            comment=$(echo "$line" | grep -oP '(ssh-rsa|ssh-ed25519|ecdsa-sha2-nistp\d+|ssh-dss)\s+\S+\s+\K.*' || echo "")
        fi

        [[ -z "$key_type" ]] && continue

        # Check for duplicates
        local is_dup=false
        local key_sig="${key_type}:${key_data}"
        for sk in "${seen_keys[@]+"${seen_keys[@]}"}"; do
            if [[ "$sk" == "$key_sig" ]]; then
                is_dup=true
                break
            fi
        done
        seen_keys+=("$key_sig")

        # Check if key comment matches expected list
        local is_expected=false
        for ek in "${EXPECTED_KEY_COMMENTS[@]}"; do
            if [[ "$comment" == *"$ek"* ]]; then
                is_expected=true
                break
            fi
        done

        local status="expected"
        if $is_dup; then
            status="duplicate"
            WARNINGS=$((WARNINGS + 1))
        elif ! $is_expected; then
            status="unexpected"
            ISSUES=$((ISSUES + 1))
        fi

        KEY_USERS+=("$user")
        KEY_TYPES+=("$key_type")
        KEY_COMMENTS+=("$comment")
        KEY_STATUSES+=("$status")
        KEY_FILES+=("$key_file")
        KEY_OPTIONS+=("$options")
    done < "$key_file"
}

# Check root authorized_keys
if [[ -d /root ]]; then
    check_authorized_keys "root" "/root"
fi

# Check all UID >= 1000 users
for i in "${!USER_NAMES[@]}"; do
    check_authorized_keys "${USER_NAMES[$i]}" "${USER_HOMES[$i]}"
done

TOTAL_KEYS=${#KEY_USERS[@]}
UNEXPECTED_KEYS=0
DUPLICATE_KEYS=0
for s in "${KEY_STATUSES[@]}"; do
    [[ "$s" == "unexpected" ]] && UNEXPECTED_KEYS=$((UNEXPECTED_KEYS + 1))
    [[ "$s" == "duplicate" ]] && DUPLICATE_KEYS=$((DUPLICATE_KEYS + 1))
done

# =============================================================================
# Output
# =============================================================================

if $OUTPUT_JSON; then
    # --- JSON output ---
    cat << JSONEOF
{
  "host": "$HOST",
  "env": "$ENV",
  "timestamp": "$(date -u '+%Y-%m-%dT%H:%M:%SZ')",
  "issues": $ISSUES,
  "warnings": $WARNINGS,
  "users": {
    "total": $TOTAL_USERS,
    "unexpected": $UNEXPECTED_USERS,
    "accounts": [
$(for i in "${!USER_NAMES[@]}"; do
    comma=""
    [[ $i -lt $((TOTAL_USERS - 1)) ]] && comma=","
    echo "      {\"name\": \"${USER_NAMES[$i]}\", \"uid\": ${USER_UIDS[$i]}, \"home\": \"${USER_HOMES[$i]}\", \"shell\": \"${USER_SHELLS[$i]}\", \"status\": \"${USER_STATUSES[$i]}\"}$comma"
done)
    ]
  },
  "sudoers": {
    "total_entries": $TOTAL_SUDO_ENTRIES,
    "blanket_nopasswd": $BLANKET_SUDO,
    "scoped_nopasswd": $SCOPED_SUDO,
    "unexpected_blanket": $UNEXPECTED_BLANKET,
    "entries": [
$(for i in "${!SUDO_USERS[@]}"; do
    comma=""
    [[ $i -lt $((TOTAL_SUDO_ENTRIES - 1)) ]] && comma=","
    # Escape the rule for JSON
    escaped_rule=$(echo "${SUDO_RULES[$i]}" | sed 's/\\/\\\\/g; s/"/\\"/g')
    echo "      {\"user\": \"${SUDO_USERS[$i]}\", \"source\": \"${SUDO_SOURCES[$i]}\", \"scope\": \"${SUDO_SCOPED[$i]}\", \"rule\": \"$escaped_rule\"}$comma"
done)
    ]
  },
  "ssh_keys": {
    "total": $TOTAL_KEYS,
    "unexpected": $UNEXPECTED_KEYS,
    "duplicates": $DUPLICATE_KEYS,
    "keys": [
$(for i in "${!KEY_USERS[@]}"; do
    comma=""
    [[ $i -lt $((TOTAL_KEYS - 1)) ]] && comma=","
    escaped_opts=$(echo "${KEY_OPTIONS[$i]}" | sed 's/\\/\\\\/g; s/"/\\"/g')
    escaped_comment=$(echo "${KEY_COMMENTS[$i]}" | sed 's/\\/\\\\/g; s/"/\\"/g')
    echo "      {\"user\": \"${KEY_USERS[$i]}\", \"type\": \"${KEY_TYPES[$i]}\", \"comment\": \"$escaped_comment\", \"status\": \"${KEY_STATUSES[$i]}\", \"file\": \"${KEY_FILES[$i]}\", \"options\": \"$escaped_opts\"}$comma"
done)
    ]
  }
}
JSONEOF
    exit 0
fi

# --- Human-readable output ---
echo ""
echo "════════════════════════════════════════════════════════════════"
echo "  User & Sudo Audit - $HOST ($ENV)"
echo "  $(date -u '+%Y-%m-%dT%H:%M:%SZ')"
echo "════════════════════════════════════════════════════════════════"

# --- Users ---
echo ""
echo "┌─ User Accounts (UID ≥ 1000) ────────────────────────────────"
for i in "${!USER_NAMES[@]}"; do
    if [[ "${USER_STATUSES[$i]}" == "unexpected" ]]; then
        icon="⚠"
    else
        icon="✓"
    fi
    printf "│  %s %-20s  uid=%-5s  %s\n" "$icon" "${USER_NAMES[$i]}" "${USER_UIDS[$i]}" "${USER_STATUSES[$i]}"
done
echo "└────────────────────────────────────────────────────────────────"

# --- Sudoers ---
echo ""
echo "┌─ Sudoers (NOPASSWD entries) ─────────────────────────────────"
for i in "${!SUDO_USERS[@]}"; do
    if [[ "${SUDO_SCOPED[$i]}" == "blanket" ]]; then
        # Check if accepted
        is_accepted=false
        for au in "${ACCEPTED_BLANKET_SUDO[@]}"; do
            [[ "${SUDO_USERS[$i]}" == "$au" ]] && is_accepted=true && break
        done
        if $is_accepted; then
            icon="⚠"
            label="blanket (accepted)"
        else
            icon="✗"
            label="blanket (UNEXPECTED)"
        fi
    elif [[ "${SUDO_SCOPED[$i]}" == "group" ]]; then
        icon="✓"
        label="group rule"
    else
        icon="✓"
        label="scoped"
    fi
    printf "│  %s %-20s  %-22s  %s\n" "$icon" "${SUDO_USERS[$i]}" "$label" "${SUDO_SOURCES[$i]}"
done
echo "└────────────────────────────────────────────────────────────────"

# --- SSH Keys ---
echo ""
echo "┌─ SSH Authorized Keys ────────────────────────────────────────"
if [[ $TOTAL_KEYS -eq 0 ]]; then
    echo "│  ℹ No authorized_keys found for any user"
else
    for i in "${!KEY_USERS[@]}"; do
        if [[ "${KEY_STATUSES[$i]}" == "unexpected" ]]; then
            icon="✗"
        elif [[ "${KEY_STATUSES[$i]}" == "duplicate" ]]; then
            icon="⚠"
        else
            icon="✓"
        fi
        opts_display=""
        if [[ -n "${KEY_OPTIONS[$i]}" ]]; then
            opts_display="  [has options]"
        fi
        printf "│  %s %-14s  %-14s  %s  (%s)%s\n" "$icon" "${KEY_USERS[$i]}" "${KEY_TYPES[$i]}" "${KEY_COMMENTS[$i]}" "${KEY_STATUSES[$i]}" "$opts_display"
    done
fi
echo "└────────────────────────────────────────────────────────────────"

# --- Summary ---
echo ""
echo "────────────────────────────────────────────────────────────────"
if [[ $ISSUES -gt 0 ]]; then
    echo "  ✗ $ISSUES issue(s), $WARNINGS warning(s)"
elif [[ $WARNINGS -gt 0 ]]; then
    echo "  ⚠ $WARNINGS warning(s), 0 issues"
else
    echo "  ✓ All checks passed"
fi
echo "    Users: $TOTAL_USERS (${UNEXPECTED_USERS} unexpected)"
echo "    Sudoers: $BLANKET_SUDO blanket, $SCOPED_SUDO scoped"
echo "    SSH keys: $TOTAL_KEYS (${UNEXPECTED_KEYS} unexpected, ${DUPLICATE_KEYS} duplicate)"
echo "────────────────────────────────────────────────────────────────"

# Exit code: 2 = issues, 1 = warnings only, 0 = clean
if [[ $ISSUES -gt 0 ]]; then
    exit 2
elif [[ $WARNINGS -gt 0 ]]; then
    exit 1
fi
exit 0
{% endraw %}
